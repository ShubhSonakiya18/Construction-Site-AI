*.mp3
*.m4a
*.ogg
*.flac
*.mp4
*.avi

# ============================================================
# Dataset Files (too large for git - use DVC or cloud storage)
# Generated output files are never committed; only .gitkeep
# files and README.md are tracked to preserve directory structure.
# ============================================================
datasets/*.jsonl
datasets/*.csv
datasets/*.parquet
datasets/generated/*
!datasets/generated/.gitkeep
datasets/raw/*.jsonl
datasets/raw/*.csv
datasets/generated/*.jsonl
datasets/generated/*.csv
datasets/validated/*.jsonl
datasets/validated/*.csv
datasets/exports/*.jsonl
datasets/exports/*.csv
datasets/exports/*.json

# ============================================================
# Speech Processing Framework (Sprint 3)
# Whisper model weights are downloaded on first use, never committed.
# Real audio recordings and generated transcripts are never committed;
# synthetic sample_audio/*.wav fixtures are explicitly allowed below.
# ============================================================
speech/.model_cache/
data/transcripts/raw/*
data/transcripts/cleaned/*
!data/transcripts/raw/.gitkeep
!data/transcripts/cleaned/.gitkeep
data/sample_audio/*.wav
!data/sample_audio/sample_*.wav

# ============================================================
# Jupyter Notebooks
# ============================================================
.ipynb_checkpoints
*.ipynb

# ============================================================
# Node.js (for future frontend)
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache
.pnpm-debug.log*
dist/
.next/
.nuxt/
.vite/

# ============================================================
# Distribution and Packaging
# ============================================================
*.manifest
*.spec

# ============================================================
# Celery (for future async tasks)
# ============================================================
celerybeat-schedule
celerybeat.pid

# ============================================================
# Redis
# ============================================================
dump.rdb

# ============================================================
# Alembic (migration output - keep versions, not generated SQL)
# ============================================================
alembic/versions/*.pyc

# ============================================================
# Temporary and Scratch Files
# ============================================================
tmp/
temp/
scratch/
.scratch/
