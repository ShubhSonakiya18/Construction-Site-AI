# ============================================================
# Construction Site AI - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ============================================================
# APPLICATION
# ============================================================
APP_NAME="Construction Site AI"
APP_VERSION="0.1.0"
APP_ENV="development"                  # development | staging | production
APP_DEBUG="true"                       # Set to false in production
APP_HOST="0.0.0.0"
APP_PORT="8000"
APP_SECRET_KEY="change-this-to-a-random-secret-key-in-production"

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"
POSTGRES_DB="construction_site_ai"
POSTGRES_USER="csai_user"
POSTGRES_PASSWORD="change-this-password"
DATABASE_URL="postgresql+asyncpg://csai_user:change-this-password@localhost:5432/construction_site_ai"

# ============================================================
# REDIS (Optional - for caching and task queue)
# ============================================================
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_URL="redis://localhost:6379/0"

# ============================================================
# OLLAMA (Local LLM inference)
# ============================================================
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:7b-instruct"
OLLAMA_TIMEOUT_SECONDS="120"
OLLAMA_MAX_RETRIES="3"

# ============================================================
# FASTER WHISPER (Local Speech-to-Text)
# ============================================================
WHISPER_MODEL_SIZE="base"              # tiny | base | small | medium | large-v2 | large-v3
WHISPER_DEVICE="cpu"                   # cpu | cuda
WHISPER_COMPUTE_TYPE="int8"            # int8 | float16 | float32
WHISPER_LANGUAGE="en"                  # ISO 639-1 language code, or "auto" for detection
WHISPER_BEAM_SIZE="5"

# ============================================================
# FILE STORAGE
# ============================================================
UPLOAD_DIR="./uploads"
AUDIO_MAX_SIZE_MB="100"
ALLOWED_AUDIO_FORMATS="wav,mp3,m4a,ogg,flac,webm"

# ============================================================
# AUTHENTICATION (JWT)
# ============================================================
JWT_SECRET_KEY="change-this-jwt-secret-key"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES="30"
JWT_REFRESH_TOKEN_EXPIRE_DAYS="7"

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL="INFO"                       # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT="json"                      # json | text (use json in production)
LOG_FILE_PATH="./logs/app.log"

# ============================================================
# CELERY (Optional - for async task processing)
# ============================================================
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"
CELERY_TASK_SERIALIZER="json"
CELERY_RESULT_SERIALIZER="json"

# ============================================================
# KNOWLEDGE BASE
# ============================================================
KNOWLEDGE_BASE_PATH="./knowledge"
CONSTRUCTION_STAGES_FILE="construction_stages.json"
DAILY_LOG_SCHEMA_FILE="construction_daily_log_schema.json"

# ============================================================
# AI SERVICE SETTINGS
# ============================================================
AI_EXTRACTION_MAX_RETRIES="3"
AI_EXTRACTION_RETRY_DELAY_SECONDS="2"
AI_JSON_VALIDATION_STRICT="true"
AI_PROMPT_TEMPLATE_DIR="./app/prompts"
