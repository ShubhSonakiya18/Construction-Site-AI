# ============================================================
# Construction Site AI — Environment Variables (Sprints 1–6)
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it is in .gitignore.
#
# All variables below are read by the current codebase.
# Redis, JWT, and Celery variables will be added in Sprint 7–8.
# ============================================================

# ============================================================
# GROQ — Cloud LLM inference (free tier)
# Free account at: https://console.groq.com
# Shared between extraction (Sprint 4) and generation (Sprint 5).
# ============================================================
GROQ_API_KEY=gsk_your_key_here

# ============================================================
# AI EXTRACTION (Sprint 4)
# Read by ExtractionConfig.from_env() in extraction/config.py
# All have sensible defaults — only GROQ_API_KEY is required.
# ============================================================
EXTRACTION_PROVIDER=groq
EXTRACTION_GROQ_MODEL=llama-3.3-70b-versatile
EXTRACTION_GROQ_TEMPERATURE=0.1
EXTRACTION_GROQ_TIMEOUT=60
EXTRACTION_MAX_RETRIES=3
EXTRACTION_KNOWLEDGE_DIR=knowledge

# ============================================================
# AI GENERATION (Sprint 5)
# Read by GenerationConfig.from_env() in generation/config.py
# Temperature is higher than extraction (0.3 vs 0.1) for more
# natural prose output.
# ============================================================
GENERATION_PROVIDER=groq
GENERATION_GROQ_MODEL=llama-3.3-70b-versatile
GENERATION_GROQ_TEMPERATURE=0.3
GENERATION_GROQ_TIMEOUT=90
GENERATION_GROQ_MAX_TOKENS=2048
GENERATION_MAX_RETRIES=3

# ============================================================
# FASTER WHISPER — Local Speech-to-Text (Sprint 3)
# Read by SpeechProcessingConfig.from_env() in speech/config.py
# The model is cached in speech/.model_cache/ after first download.
# ============================================================
SPEECH_WHISPER_MODEL_SIZE=base
# Options: tiny (75MB) | base (150MB) | small (250MB) | medium (1.5GB) | large-v3 (3GB)

SPEECH_WHISPER_DEVICE=cpu
# Options: cpu | cuda | auto

SPEECH_WHISPER_COMPUTE_TYPE=int8
# Options: int8 (CPU default) | float16 (GPU) | float32 (most accurate)

SPEECH_WHISPER_LANGUAGE=en
# Leave empty for auto-detect. ISO 639-1 code (en, es, fr, ...)

SPEECH_MAX_FILE_SIZE_MB=500
SPEECH_MAX_DURATION_SECONDS=7200
SPEECH_ENABLE_NOISE_REDUCTION=false
SPEECH_MODELS_DIR=speech/.model_cache
SPEECH_MAX_RETRIES=3
# Retry attempts if Whisper transcription fails on a segment

# ============================================================
# DATABASE (Sprint 6)
# Read by database/config.py — DatabaseConfig.from_env()
# Format: postgresql://user:password@host:port/dbname
# For local development: postgresql://postgres:postgres@localhost:5432/construction_site_ai
# For testing (unit tests use SQLite in-memory — no DATABASE_URL needed):
#   pytest tests/ -v             → runs all tests, no DB required
#   pytest tests/test_db_*.py   → DB tests, also use SQLite in-memory (no DB required)
# ============================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/construction_site_ai
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ============================================================
# HUGGINGFACE HUB
# If HuggingFace.co is blocked on your network and the Whisper
# model is already cached locally, set this to 1 to skip the
# remote version check and load directly from SPEECH_MODELS_DIR.
# ============================================================
HF_HUB_OFFLINE=0
